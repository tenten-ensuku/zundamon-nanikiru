# Discord Developer Portal -> Bot -> Token. Never commit the real value.
DISCORD_BOT_TOKEN=

# IDs for the target Discord server/channel and explanation author.
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_EXPLAINER_USER_ID=

# Admin editor. Keep the real password only in .env or the hosting secret settings.
ADMIN_PASSWORD=

# Optional comma-separated production origins allowed to call the API.
ALLOWED_ORIGINS=
